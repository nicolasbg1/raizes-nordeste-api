{
  "info": {
    "name": "Raizes do Nordeste API",
    "description": "Colecao da API Raizes do Nordeste.\n\nCOMO USAR:\n1. Suba a API (npm run dev) e rode o seed.\n2. O baseUrl ja vem preenchido (http://localhost:3000), nao precisa configurar nada.\n3. Na pasta Auth rode um dos Login. Ele salva o token sozinho na variavel {{token}}, entao as outras requisicoes ja saem autenticadas.\n\nIMPORTANTE - qual login usar:\n- Login (cliente): para pedidos, pagamento, fidelidade e os erros.\n- Login (admin): para criar unidade/produto e mexer no estoque.\n- Login (gerente): para atualizar status do pedido.\nSe der 403, é porque o token logado nao tem permissao - rode o Login do perfil certo antes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (cliente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// guarda o token retornado para usar nas outras requisicoes",
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"cliente123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// salva o token do admin pra usar nas rotas de unidade, produto e estoque",
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@raizesnordeste.com\",\n  \"senha\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (gerente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// salva o token do gerente pra atualizar status de pedido",
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gerente@raizesnordeste.com\",\n  \"senha\": \"gerente123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Registro de cliente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Silva\",\n  \"email\": \"maria@exemplo.com\",\n  \"senha\": \"senha123\",\n  \"aceitaFidelidade\": true\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/registro", "host": ["{{baseUrl}}"], "path": ["auth", "registro"] }
          }
        },
        {
          "name": "Perfil do usuario logado",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/perfil", "host": ["{{baseUrl}}"], "path": ["auth", "perfil"] }
          }
        }
      ]
    },
    {
      "name": "Unidades",
      "item": [
        {
          "name": "Listar unidades",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/unidades", "host": ["{{baseUrl}}"], "path": ["unidades"] }
          }
        },
        {
          "name": "Detalhes da unidade",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/unidades/1", "host": ["{{baseUrl}}"], "path": ["unidades", "1"] }
          }
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "Listar produtos (paginado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/produtos?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["produtos"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Detalhe do produto",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/produtos/1", "host": ["{{baseUrl}}"], "path": ["produtos", "1"] }
          }
        }
      ]
    },
    {
      "name": "Cardapio",
      "item": [
        {
          "name": "Cardapio da unidade",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/unidades/1/cardapio", "host": ["{{baseUrl}}"], "path": ["unidades", "1", "cardapio"] }
          }
        }
      ]
    },
    {
      "name": "Estoque",
      "item": [
        {
          "name": "Consultar estoque da unidade",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/estoque/1", "host": ["{{baseUrl}}"], "path": ["estoque", "1"] }
          }
        },
        {
          "name": "Movimentar estoque (entrada)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"produtoId\": 1,\n  \"tipo\": \"ENTRADA\",\n  \"quantidade\": 50,\n  \"motivo\": \"Reposicao semanal\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/estoque/movimentar", "host": ["{{baseUrl}}"], "path": ["estoque", "movimentar"] }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Criar pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"TOTEM\",\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 2 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Listar pedidos (filtro por canal)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/pedidos?canalPedido=TOTEM&status=RECEBIDO&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["pedidos"],
              "query": [
                { "key": "canalPedido", "value": "TOTEM" },
                { "key": "status", "value": "RECEBIDO" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Detalhe do pedido",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pedidos/1", "host": ["{{baseUrl}}"], "path": ["pedidos", "1"] }
          }
        },
        {
          "name": "Atualizar status do pedido",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"EM_PREPARO\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos/1/status", "host": ["{{baseUrl}}"], "path": ["pedidos", "1", "status"] }
          }
        },
        {
          "name": "Cancelar pedido",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pedidos/1", "host": ["{{baseUrl}}"], "path": ["pedidos", "1"] }
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "Processar pagamento mock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formaPagamento\": \"MOCK\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/pagamentos/1", "host": ["{{baseUrl}}"], "path": ["pagamentos", "1"] }
          }
        },
        {
          "name": "Pagamento recusado (acima de R$500)",
          "description": "Mostra o pagamento sendo recusado. Antes, crie um pedido caro na pasta Pedidos (ex: 16x Baiao de Dois = R$526,40) e troque o id da URL pelo id desse pedido. Valores acima de R$500 voltam como RECUSADO e o pedido continua RECEBIDO.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"formaPagamento\": \"MOCK\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/pagamentos/2", "host": ["{{baseUrl}}"], "path": ["pagamentos", "2"] }
          }
        },
        {
          "name": "Consultar pagamento",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pagamentos/1", "host": ["{{baseUrl}}"], "path": ["pagamentos", "1"] }
          }
        }
      ]
    },
    {
      "name": "Fidelidade",
      "item": [
        {
          "name": "Saldo de pontos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/fidelidade/saldo", "host": ["{{baseUrl}}"], "path": ["fidelidade", "saldo"] }
          }
        },
        {
          "name": "Historico de pontos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/fidelidade/historico", "host": ["{{baseUrl}}"], "path": ["fidelidade", "historico"] }
          }
        },
        {
          "name": "Resgatar pontos",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pontos\": 100\n}"
            },
            "url": { "raw": "{{baseUrl}}/fidelidade/resgatar", "host": ["{{baseUrl}}"], "path": ["fidelidade", "resgatar"] }
          }
        }
      ]
    },
    {
      "name": "Erros",
      "item": [
        {
          "name": "Sem token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Sem permissao (403)",
          "description": "Logado como CLIENTE tentando criar unidade (apenas ADMIN/GERENTE).",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Unidade Nova\",\n  \"endereco\": \"Rua Teste, 123\",\n  \"cidade\": \"Fortaleza\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/unidades", "host": ["{{baseUrl}}"], "path": ["unidades"] }
          }
        },
        {
          "name": "Campo obrigatorio faltando (422)",
          "description": "Pedido sem canalPedido.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Estoque insuficiente (409)",
          "description": "Pedido com quantidade acima do estoque disponivel.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"APP\",\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 99999 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Produto inexistente (404)",
          "description": "Pedido com um produtoId que nao existe.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"APP\",\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 99999, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        },
        {
          "name": "Canal invalido (422)",
          "description": "canalPedido fora do enum permitido.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"DELIVERY\",\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 1 }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/pedidos", "host": ["{{baseUrl}}"], "path": ["pedidos"] }
          }
        }
      ]
    }
  ]
}
